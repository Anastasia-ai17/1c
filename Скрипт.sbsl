метод ТипСтроковыеЗначения()
    Консоль.Записать("Строка с \"кавычками\"")
    Консоль.Записать("Однострочная строка")
    Консоль.Записать("Многострочная \нстрока")
    пер Число = 100
    Консоль.Записать("Заряжен на "+ Число + "%\нЗаряжен на " + Число/2 + "%\нЗаряжен на "+ Число/4 + "%")
;
метод ТипЧисловыеЗначения()
    пер Покупка = 1200
    пер Скидка = 7
    Консоль.Записать("Зинаида Петровна, с вас "+ (Покупка - (Покупка*Скидка)/100) +" рублей")
    пер Переменная1 = 10
    пер Переменная2 = 100
    пер Телефон = 0321
    пер Выражение = ((-(Переменная1 + Переменная2)/(Переменная2*Переменная1))%(Переменная2-Переменная1))-Телефон
    Консоль.Записать(Выражение)
;
метод ТипДата()
    пер Сейчас = Дата.Сейчас()
    пер Потом = Сейчас.ДобавитьГоды(7).ДобавитьМесяцы(3).ДобавитьДни(5)
    Консоль.Записать(Сейчас)
    Консоль.Записать(Потом)
;
метод ТипВремя()
    пер Сейчас = Время.Сейчас()
    пер Потом = Сейчас.ДобавитьСекунды(5000)
    Консоль.Записать(Сейчас)
    Консоль.Записать(Потом)
;
метод ТипДатаВремя()
    пер Сейчас = ДатаВремя.Сейчас()
    пер Макс = ДатаВремя{Максимум}
    пер Разница = Макс - Сейчас
    Консоль.Записать(Сейчас)
    Консоль.Записать(Макс)
    Консоль.Записать(Разница)
;
метод ТипДлительность()
    пер Сейчас = ДатаВремя.Сейчас()
    пер КонецДня = ДатаВремя.Сейчас().КонецДня()
    пер КонецПары = новый ДатаВремя(2026,3,4,16,40,00,000)
    пер ДоКонцаДня = КонецДня - Сейчас
    пер ДоКонцаПары = КонецПары - Сейчас
    Консоль.Записать(Сейчас)
    Консоль.Записать(КонецДня)
    Консоль.Записать(ДоКонцаДня)
    Консоль.Записать(ДоКонцаПары)
;
метод ТипЧасовойПояс()
    пер СейчасЧебоксары = ДатаВремя.Сейчас().ДобавитьЧасы(3)
    Консоль.Записать(СейчасЧебоксары)
;
метод ТипБулево()
    пер Выражение1 = (Истина или Ложь) и (Истина и Ложь)
    пер Выражение2 = не (Истина и Ложь) или (Истина и Истина и Ложь или не Истина)
    пер Выражение3 = (4375 / 16 * 0.9) > - (675 + 435 / 100 * (-73)) и не Ложь
    Консоль.Записать(Выражение1)
    Консоль.Записать(Выражение2)
    Консоль.Записать(Выражение3)
;