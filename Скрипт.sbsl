метод Один()
    знч Возраст = Консоль.СчитатьЧисло("Введите ваш возраст: ")
    пер Результат: Строка
    если Возраст > 17
        Результат = "Вы совершеннолетний!"
    иначе
        Результат = "Вы несовершеннолетний("
    ;
    Консоль.Записать(Результат)
;
метод Два()
    знч ФИО = Консоль.СчитатьСтроку("Введите ФИО в формате Иванов И.И.: ")
    пер МассивФИО = ФИО.Разделить(" ")
    пер Фамилия = МассивФИО.Получить(0).ВНижнийРегистр()
    Фамилия = Фамилия.Заменить(Фамилия.ПодстрокаСНачала(1),Фамилия.ПодстрокаСНачала(1).ВВерхнийРегистр(), Истина)
    пер ИмяОтч = МассивФИО.Получить(1).ВВерхнийРегистр()
    Консоль.Записать(Фамилия + " " + ИмяОтч)
;
метод Три()
    знч Икс = Консоль.СчитатьЧисло("Введите x: ")
    пер Выражение = (Sin(Log(Икс)))/(Степень(Икс,2))
    Консоль.Записать(Выражение)
;
метод Четыре()
    пер Стих = "Точка ставится в конце.\нПравда же, подружки?\нЕсли точки на лице,\нИх зовут веснушки."
    пер Итого = Стих.Удалить(".").Удалить(",").Удалить("?")
    Консоль.Записать(Итого)
;
метод Пять()
    пер Стих = "Точка ставится в конце.\нПравда же, подружки?\нЕсли точки на лице,\нИх зовут веснушки."
    пер Стих2 = Стих.Разделить("\н")
    пер МассивСтрок = новый Массив<Строка>()
    для Строка из Стих2
        МассивСтрок.Добавить(Строка.Обрезать(10))
    ;
    пер Результат: Строка = Строки.Соединить(МассивСтрок, Символы.НОВАЯ_СТРОКА)
    Консоль.Записать(Результат)
;
метод Шесть()
    знч А = Консоль.СчитатьЧисло("Введите а: ")
    пер Выражение = Степень(Sin(А),2) + Степень(Cos(А),2) - 2*Степень(А,7)
    Консоль.Записать(Выражение)
;
метод Семь()
    знч А = Консоль.СчитатьЧисло("Введите а: ")
    знч Б = Консоль.СчитатьЧисло("Введите б: ")
    пер Дробь = А/Б
    пер Цел = Дробь.ЦелаяЧасть()
    пер Др = Дробь - Цел
    если Др != 0
        пер Пер = "%Др"
        пер Массив = Пер.Разделить(".")
        Консоль.Записать("Целая часть: %{Цел}. Дробная часть: %{Массив.Получить(1)}")
    иначе
        Консоль.Записать("Целая часть: %{Цел}. Дробная часть: %{Др}")
    ;
;
метод Восемь()
    пер Сейчас = ДатаВремя.Сейчас()
    Консоль.Записать(Сейчас)
    Консоль.Записать("Начало года: %{Сейчас.НачалоГода()}. Конец года: %{Сейчас.КонецГода()}")
    Консоль.Записать("Начало квартала: %{Сейчас.НачалоКвартала()}. Конец квартала: %{Сейчас.КонецКвартала()}")
    Консоль.Записать("Начало месяца: %{Сейчас.НачалоМесяца()}. Конец месяца: %{Сейчас.КонецМесяца()}")
    Консоль.Записать("Начало недели: %{Сейчас.НачалоНедели()}. Конец недели: %{Сейчас.КонецНедели()}")
    Консоль.Записать("Начало дня: %{Сейчас.НачалоДня()}. Конец дня: %{Сейчас.КонецДня()}")
    Консоль.Записать("Начало часа: %{Сейчас.НачалоЧаса()}. Конец часа: %{Сейчас.КонецЧаса()}")
    Консоль.Записать("Начало минуты: %{Сейчас.НачалоМинуты()}. Конец минуты: %{Сейчас.КонецМинуты()}")
;
метод Девять()
    пер МояДата = Дата{2007-10-30}
    Консоль.Записать(МояДата.ДеньГода())
;
метод Десять()
    знч Число = Консоль.СчитатьЧисло("Введите целое положительное число: ")
    пер ЧислоСтрока = "%Число"
    пер Длина = ЧислоСтрока.Длина()
    пер Сумма = 0
    для Элемент из ЧислоСтрока
        Сумма += новый Число(Элемент)
    ;
    Консоль.Записать("Сумма цифр: %{Сумма}. Длина числа: %{Длина}")
;
метод Одиннацать()
    знч Строка = Консоль.СчитатьСтроку("Введите произвольную строку: ")
    пер МассивЦифр = новый Массив<Строка>()
    пер МассивБукв = новый Массив<Строка>()
    для Элемент из Строка
        если Элемент.ТолькоБуквы()
            МассивБукв.Добавить(Элемент)
        иначе если Элемент.ТолькоЦифры()
            МассивЦифр.Добавить(Элемент)
        ;
    ;
    Консоль.Записать(Строки.Соединить(МассивЦифр))
    Консоль.Записать(Строки.Соединить(МассивБукв))
;
метод Двенадцать()
    пер Строка = "Звук распространяется в разных средах с неодинаковой скоростью. В воздухе при нормальных условиях это примерно 331 метр в секунду. Однако в твердых телах, например в стали, скорость звука может превышать 5000 метров в секунду."
    пер ДлинаТекста = Строка.Длина()
    пер Массив = новый Массив<Строка>()
    пока Строка.Длина() != 0
        Массив.Добавить(Строка.Обрезать(15))
        Строка = Строка.Заменить(Строка.Обрезать(15), "", Истина)
    ;
    Консоль.Записать(Строки.Соединить(Массив, Символы.НОВАЯ_СТРОКА))
    Консоль.Записать("Длина текста: %{ДлинаТекста}")
;
метод Тринадцать()
    пер МассивЧисел = новый Массив<Число>()
    для Индекс=1 по 100
        если Индекс%2==0 и Индекс%3==0
            МассивЧисел.Добавить(Индекс)
        ;
    ;
    Консоль.Записать(МассивЧисел)
;